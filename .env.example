# ─────────────────────────────────────────────────────────────────────────────
# YouTube Downloader API – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=YouTube Downloader API
APP_VERSION=1.0.0
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production replace * with your actual frontend domain:
# ALLOWED_ORIGINS=https://myapp.vercel.app,https://www.myapp.com
ALLOWED_ORIGINS=*

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_DOWNLOAD_PER_MINUTE=3

# ── Download ──────────────────────────────────────────────────────────────────
TEMP_DIR=app/temp
MAX_FILE_AGE_MINUTES=30
DOWNLOAD_TIMEOUT=300
CHUNK_SIZE=1048576

# ── yt-dlp ────────────────────────────────────────────────────────────────────
# REQUIRED for Render/server deployments:
# Paste the base64-encoded content of your YouTube cookies.txt here.
# How to get it:
#   1. Install "Get cookies.txt LOCALLY" Chrome extension
#   2. Log in to YouTube (youtube.com)
#   3. Click the extension on youtube.com → Export → "Cookies for current site"
#   4. Base64 encode the file:
#        Windows:  certutil -encode cookies.txt cookies_b64.txt  (copy content between BEGIN/END)
#        Mac/Linux: base64 -i cookies.txt | tr -d '\n'
#   5. Paste the single-line base64 string as the value below
YT_COOKIES_BASE64=

# Alternative: direct path to cookies.txt (only works if file is on the server)
YT_DLP_COOKIES_FILE=

# Maximum number of playlist items to extract per request
MAX_PLAYLIST_ITEMS=50

# ── Security ──────────────────────────────────────────────────────────────────
# Optional API key guard. If set, requests must include:
#   Authorization: Bearer <your-key>
# Leave blank to disable (open API).
API_KEY=
